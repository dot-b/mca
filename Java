public class StringAndStringBuffer { 
public static void main(String[] args) { 
String s1 = "Hello"; 
String s2 = s1.concat("world"); 
System.out.println("Original Value: " + s1); 
System.out.println("After modification: " + s2); 
System.out.println("Length: " + s2.length()); 
System.out.println("Upper Case: " + s2.toUpperCase()); 
System.out.println("Character at: " + s2.charAt(2)); 
StringBuffer sb = new StringBuffer("Hello"); 
System.out.println("String Buffer example: "); 
System.out.println("Original StringBuffer: " + sb); 
System.out.println("Append: " + sb.append("world")); 
System.out.println("Insert: " + sb.insert(5, ", ")); 
System.out.println("Replace: " + sb.replace(6, 12, "java")); 
System.out.println("Delete: " + sb.delete(5, 6)); 
System.out.println("Reverse: " + sb.reverse()); 
} 
} 

