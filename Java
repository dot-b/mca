abstract class Vehicle { 
String brand; 
Vehicle(String brand) { 
this.brand = brand; 
} 
abstract void start(); 
final void fuelType() { 
System.out.println("Fuel Type: Petrol"); 
} 
} 
class Car extends Vehicle { 
int speed; 
Car(String brand, int speed) { 
super(brand); 
this.speed = speed; 
} 
@Override 
void start() { 
System.out.println("Car brand: " + brand + " started at speed: " + speed); 
} 
} 
public class Main { 
public static void main(String[] args) { 
Car c = new Car("Toyota", 120); 
c.start(); 
c.fuelType(); 
} 
} 


