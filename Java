class Calculator { 
int a; 
int b; 
// Default constructor 
Calculator() { 
this.a = 0; 
this.b = 0; 
System.out.println("Default constructor called: a=" + a + ", b=" + b); 
} 
// Parameterized constructor 
Calculator(int a, int b) { 
this.a = a; 
this.b = b; 
System.out.println("Parameterized constructor called: a=" + a + ", b=" + b); 
} 
// Overloaded add - two parameters 
public int add(int a, int b) { 
return a + b; 
} 
// Overloaded add - three parameters 
public int add(int a, int b, int c) { 
} 
} 
return a + b + c; 
public class Main { 
public static void main(String[] args) { 
// Object using default constructor 
Calculator c1 = new Calculator(); 
System.out.println("Sum of 2 numbers: " + c1.add(10, 20)); 
System.out.println("Sum of 3 numbers: " + c1.add(10, 20, 30)); 
// Object using parameterized constructor 
Calculator c2 = new Calculator(5, 10); 
System.out.println("Sum of 2 numbers: " + c2.add(5, 10)); 
System.out.println("Sum of 3 numbers: " + c2.add(5, 10, 15)); 
} 
} 

