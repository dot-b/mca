class Student { 
    private String name; 
    private int age; 
    public void setData(String n, int a) { 
        name = n; 
        age = a; 
    } 
    public void Display() { 
        System.out.println("Name: " + name); 
        System.out.println("Age: " + age); 
    } 
} 
public class Main { 
   public static void main(String[] args) { 
       Student s1 = new Student(); 
       s1.setData("Anu", 20); 
       s1.Display(); 
   } 
} 
